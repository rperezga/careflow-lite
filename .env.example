# Backend
NODE_ENV=development
PORT=4000
# Interface to bind to. Defaults to loopback: the reverse proxy / tunnel reaches the API over
# localhost, so the API never needs to be reachable from the network itself.
HOST=127.0.0.1
# Mongo (careflow-lite deploy uses 127.0.0.1 only, with auth)
MONGODB_URI=mongodb://127.0.0.1:27017/careflow_lite
JWT_SECRET=change-me-in-prod
COOKIE_SECURE=false
