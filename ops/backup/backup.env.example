# Copy to /etc/careflow/backup.env, fill in, and chmod 600. NEVER commit the real file.
#
# Use a DEDICATED user with the `backup` role — not the application user (which can write) and not
# root. If this credential ever leaks, it can read the data and nothing else.
#
#   use admin
#   db.createUser({ user: "careflow_backup", pwd: passwordPrompt(),
#                   roles: [{ role: "backup", db: "admin" }, { role: "read", db: "careflow_lite" }] })
#
MONGO_URI="mongodb://careflow_backup:<PASSWORD>@127.0.0.1:27017/?authSource=admin"
DB_NAME="careflow_lite"
BACKUP_DIR="/home/roger/backups/mongo"
RETENTION_DAYS="7"

# Optional. If unset, failures are still logged — they just are not pushed anywhere.
# A backup that fails silently is worse than no backup: it hands you false confidence.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
