# Copy to /etc/careflow/backup.env, fill in, chmod 600. NEVER commit the real file.
#
# --- The backup identity: read-only, and that is the point -------------------------------------
# The nightly backup and the weekly restore drill both run with THIS credential, and it can only
# read. The drill restores into a throwaway MongoDB instance it starts and deletes itself, so it
# never needs write access to the real server. A process whose job is to protect the data should
# not be able to destroy it.
#
#   use admin
#   db.createUser({ user: "careflow_backup", pwd: passwordPrompt(),
#                   roles: [{ role: "backup", db: "admin" }] })
#
# `backup` covers every database, present and future — including any created after today.
#
MONGO_URI="mongodb://careflow_backup:<PASSWORD>@127.0.0.1:27017/?authSource=admin"

# --- The restore identity: only needed on a bad day --------------------------------------------
# Restoring writes, so it needs a stronger credential. It is DELIBERATELY separate, and it is fine
# to leave it unset: mongo-restore.sh is run by a human, who can pass an admin URI then. What you
# do not want is the nightly automation holding a credential that can drop your database.
#
# RESTORE_MONGO_URI="mongodb://mongo_admin:<PASSWORD>@127.0.0.1:27017/?authSource=admin"

BACKUP_DIR="/home/roger/backups/mongo"
RETENTION_DAYS="7"
DRILL_PORT="27099"

# --- Alerts ------------------------------------------------------------------------------------
# Optional, but strongly recommended. A backup that fails silently is worse than no backup: it
# hands you confidence you did not earn, and you find out on the one night it matters.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
